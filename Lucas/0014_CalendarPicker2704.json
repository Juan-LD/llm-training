{
  "prompt": {
    "EN": "Create a whatsApp flow that allows the user to select their vacation period using the calendar"
  },
  	"ok_flows":
  [
    {
      "EN":
					  {
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {},
  "screens": [
    {
      "id": "DEMO_SCREEN",
      "terminal": true,
      "title": "Dates",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "CalendarPicker",
            "name": "calendar_range",
            "title": "Available dates",
            "label": {
              "start-date": "Start date",
              "end-date": "End date"
            },
            "helper-text": {
              "start-date": "Select from date",
              "end-date": "Select to date"
            },
            "required": {
              "start-date": true,
              "end-date": false
            },
            "mode": "range",
            "min-date": "2023-10-21",
            "max-date": "2026-12-31",
            "unavailable-dates": [
              "2024-11-28",
              "2026-11-01"
            ],
            "include-days": [
              "Mon",
              "Tue",
              "Wed",
              "Thu",
              "Fri"
            ],
            "min-days": 5,
            "max-days": 25,
            "init-value": {
              "start-date": "2026-04-30",
              "end-date": "2026-05-15"
            },
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "calendar_range": "${form.calendar_range}"
              }
            }
          },
          {
            "type": "Footer",
            "label": "Reserve",
            "on-click-action": {
              "name": "data_exchange"
            }
          }
        ]
      }
    }
  ]
}
	}
