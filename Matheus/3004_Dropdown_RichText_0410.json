            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "navigate",
              "next": {
                "name": "FS",
                "type": "screen"
                }
              }
          }
        ]
      }
    },
    {
      "id": "FS",
      "title": "Demo screen",
      "data": {
        "all_service": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
                    {
                      "id": "repair",
