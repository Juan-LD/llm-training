{
  "prompt": {
    "EN": "Create a WhatsApp Flow with a single screen for a service inquiry. The screen should start with a 'RichText' component that uses a header to welcome the user and explain the purpose of the form. Below the text, include a 'Dropdown' component named 'service_type' that allows users to select one option from a list of services: 'Repair', 'Maintenance', and 'Installation'. The flow must conclude with a Footer button to submit the selection."
  },
  "ok_flows": [
    {
      "EN": {
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "TOC": [
      "FS"
    ],
    "FS": []
  },
  "screens": [
    {
      "id": "TOC",
      "terminal": true,
      "data": {
        "text": {
          "type": "string",
          "__example__": "Service Request\nPlease select the type of service you require from the list below so we can better assist you."
        }
      },
      "title": "Service Request",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "RichText",
            "text": "${data.text}"
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "navigate",
              "next": {
                "name": "FS",
                "type": "screen"
                }
              }
          }
        ]
      }
    },
    {
      "id": "FS",
      "title": "Demo screen",
      "data": {
        "all_service": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
                    {
                      "id": "repair",
                      "title": "Repair"
                    },
                    {
                      "id": "maintenance",
                      "title": "Maintenance"
                    },
                    {
                      "id": "installation",
                      "title": "Installation"
                    }
                  ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "text_input_form",
            "children": [
              {
                "type": "Dropdown",
                "name": "service",
                "label": "service",
                "required": true,
                "data-source": "${data.all_service}",
                "on-select-action": {
                  "name": "data_exchange",
                  "payload": {
                    "service": "${form.service}"
                  }
                }
              },
              {
                "type": "Footer",
                "label": "Continue",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {}
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
    }
  ],
  "ko_flows": [
    {
      "EN": {
