                    },
                    {
                      "id": "maintenance",
                      "title": "Maintenance"
                    },
                    {
                      "id": "installation",
                      "title": "Installation"
                    }
                  ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
