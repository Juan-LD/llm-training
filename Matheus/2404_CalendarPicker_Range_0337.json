{
  "prompt": {
    "EN": "Create a WhatsApp Flow with a single terminal screen titled 'Demo screen'. The screen should include a CalendarPicker in 'range' mode named 'calendar_range'. Configure it with a 'Start date' (required) and an 'End date' (optional), including helper texts for both. The selection should be restricted to weekdays (Mon-Fri) between 2024-10-21 and 2025-12-12, excluding 2024-11-28 and 2024-11-01. Set a minimum range of 3 days and a maximum of 10 days, with an initial value from 2024-10-22 to 2024-10-25. Selecting a range should trigger a 'data_exchange' action. Finally, add a Footer labeled 'Continue' that also triggers a 'data_exchange' action."
  },
  "ok_flows": [
    {
      "EN": {
        "version": "7.3",
        "data_api_version": "3.0",
        "routing_model": {},
        "screens": [
          {
            "id": "DEMO_SCREEN",
            "terminal": true,
            "title": "Demo screen",
            "layout": {
              "type": "SingleColumnLayout",
              "children": [
                {
                  "type": "CalendarPicker",
                  "name": "calendar_range",
                  "title": "Range calendar",
                  "description": "Use this to select a date range",
                  "label": {
                    "start-date": "Start date",
                    "end-date": "End date"
                  },
                  "helper-text": {
                    "start-date": "Select from date",
                    "end-date": "Select to date"
                  },
                  "required": {
                    "start-date": true,
                    "end-date": false
                  },
                  "mode": "range",
                  "min-date": "2024-10-21",
                  "max-date": "2025-12-12",
                  "unavailable-dates": [
                    "2024-11-28",
                    "2024-11-01"
                  ],
                  "include-days": [
                    "Mon",
                    "Tue",
                    "Wed",
                    "Thu",
                    "Fri"
                  ],
                  "min-days": 3,
                  "max-days": 10,
                  "init-value": {
                    "start-date": "2024-10-22",
                    "end-date": "2024-10-25"
                  },
                  "on-select-action": {
                    "name": "data_exchange",
                    "payload": {
                      "calendar_range": "${form.calendar_range}"
                    }
                  }
                },
                {
                  "type": "Footer",
                  "label": "Continue",
                  "on-click-action": {
                    "name": "data_exchange",
                    "payload": {}
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "ko_flows": [
    {
      "EN": {
        "version": "7.3",
        "data_api_version": "3.0",
        "routing_model": {},
        "screens": [
          {
            "id": "DEMO_SCREEN",
            "terminal": true,
            "title": "Demo screen",
            "layout": {
              "type": "SingleColumnLayout",
              "children": [
                {
                  "type": "Footer",
                  "label": "Continue",
                  "on-click-action": {
                    "name": "data_exchange",
                    "payload": <>
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}

