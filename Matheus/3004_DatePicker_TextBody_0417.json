    {
      "id": "DEMO_SCREEN",
      "terminal": true,
      "title": "Demo screen",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextBody",
            "text": "Schedule Appointment\nPlease select a convenient date below."
          },
          {
            "type": "DatePicker",
            "name": "date",
            "label": "Date",
            "min-date": "2024-10-21",
            "max-date": "2024-11-12",
            "unavailable-dates": [
              "2024-10-28",
              "2024-11-01"
            ],
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "date": "${form.date}"
              }
            }
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {}
            }
          }
        ]
      }
    }
  ]
}
    }
