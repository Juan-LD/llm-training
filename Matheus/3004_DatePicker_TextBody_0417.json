{
  "prompt": {
    "EN": "Create a WhatsApp Flow with a single screen that includes a 'TextBody' component to display a heading and a 'DatePicker' component to allow the user to select their preferred appointment date."
  },
  "ok_flows": [
    {
      "EN": {
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {},
  "screens": [
    {
      "id": "DEMO_SCREEN",
      "terminal": true,
      "title": "Demo screen",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextBody",
            "text": "Schedule Appointment\nPlease select a convenient date below."
          },
          {
            "type": "DatePicker",
            "name": "date",
            "label": "Date",
            "min-date": "1988-10-21",
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "date": "${form.date}"
              }
            }
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {}
            }
          }
        ]
      }
    }
  ]
}
    }
  ],
  "ko_flows": [
    {
      "EN": {
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": (),
