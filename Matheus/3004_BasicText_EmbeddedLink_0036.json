{
  "prompt": {
    "EN": "Create a WhatsApp flow for a policy update notification. The screen must feature a 'Text' component that includes a Heading, Subheading, Body, and Caption explaining the changes. This must be accompanied by an 'EmbeddedLink' component that provides a direct URL for the user to read the full terms and conditions document."
  },
  "ok_flows": [
    {
      "EN": {
  "version": "7.3",
  "screens": [
    {
      "id": "DEMO_SCREEN",
      "title": "Demo Screen",
      "terminal": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Privacy Policy Update",
            "visible": true
          },
          {
            "type": "TextSubheading",
            "text": "Effective May 2026",
            "visible": true
          },
          {
            "type": "TextBody",
            "text": "We have updated our privacy practices to better protect your personal data and comply with new international standards."
          },
          {
            "type": "TextCaption",
            "text": "Please review the changes carefully."
          },
          {
            "type": "EmbeddedLink",
            "text": "Read the full Policy here",
            "on-click-action": {
              "name":"open_url", 
              "url": "https://www.example.com/privacy"
            }
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "complete",
              "payload": {}
            }
          }
        ]
      }
    }
  ]
}
    }
  ],
