{
  "prompt": {
    "EN": "Create a WhatsApp flow to select a travel package, then start and end dates, using a 'RadioButtonsGroup' and 'CalendarPicker'."
  },
  "ok_flows": [
    {
      "EN": {
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {},
  "screens": [
    {
      "id": "DEMO_SCREEN",
      "terminal": true,
      "title": "Demo screen",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "RadioButtonsGroup",
            "name": "packages",
            "required": true,
            "data-source": [
              {
                "id": "1",
                "title": "Tropical Beach Vacation",
                "description": "Enjoy 7 nights and 8 days at a luxury beach resort in Bali. Including flights and stays",
                "alt-text": "beach vacation"
              },
              {
                "id": "2",
                "title": "Mountain Adventure",
                "description": "Embark on a 5-day guided trek in the Swiss Alps. Package includes flights and stays"
              },
              {
                "id": "3",
                "title": "City Break",
                "description": "Explore the sights and sounds of New York City with our 4 nights and 5 days package"
              },
              {
                "id": "4",
                "title": "Historical Tour",
                "description": "Take a 7-day historical tour of Rome, Italy. Package includes flights and stays"
               }
            ],
            "label": "Explore our exciting packages"
          },
          {
            "type": "CalendarPicker",
            "name": "calendar_range",
            "title": "Calendar",
            "description": "Use this to select a date range",
            "label": {
              "start-date": "Start date",
              "end-date": "End date"
            },
            "helper-text": {
              "start-date": "Select from date",
              "end-date": "Select to date"
            },
            "required": {
              "start-date": true,
              "end-date": false
            },
            "mode": "range",
            "min-date": "2024-10-21",
            "max-date": "2025-12-12",
            "unavailable-dates": [
              "2024-11-28",
              "2024-11-01"
            ],
            "include-days": [
              "Mon",
              "Tue",
              "Wed",
              "Thu",
              "Fri"
            ],
            "min-days": 3,
            "max-days": 10,
            "init-value": {
              "start-date": "2024-10-22",
              "end-date": "2024-10-25"
            },
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "calendar_range": "${form.calendar_range}"
              }
            }
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {}
            }
          }
        ]
      }
    }
  ]
}
