{
  "prompt": {
    "EN": "Create a WhatsApp Flow with a single terminal screen titled 'Demo screen'. The screen must feature a ChipsSelector component named 'chips' that allows users to personalize their experience by choosing interests. It should include a label, a description, and allow a maximum of 2 selections. The available options are 'Room layouts', 'Lighting', 'Renovation', and 'Furnitures'. Finally, include a Footer labeled 'Continue' that executes the 'complete' action."
  },
  "ok_flows": [
    {
      "EN": {
        "version": "6.3",
        "screens": [
          {
            "id": "DEMO_SCREEN",
            "terminal": true,
            "title": "Demo screen",
            "layout": {
              "type": "SingleColumnLayout",
              "children": [
                {
                  "type": "ChipsSelector",
                  "name": "chips",
                  "label": "Personalize your experience",
                  "description": "Choose your interests to get personalized design ideas and solution",
                  "max-selected-items": 2,
                  "data-source": [
                    {
                      "id": "room_layout",
                      "title": "🏡 Room layouts"
                    },
                    {
                      "id": "lighting",
                      "title": "💡 Lighting"
                    },
                    {
                      "id": "renovation",
                      "title": "🛠️ Renovation"
                    },
                    {
                      "id": "furnitures",
                      "title": "📐 Room layouts"
                    }
                  ]
                },
                {
                  "type": "Footer",
                  "label": "Continue",
                  "on-click-action": {
                    "name": "complete",
                    "payload": {}
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "ko_flows": [
    {
      "EN": {
        "version": "6.3",
        "screens": [
          {
            "id": "DEMO_SCREEN",
            "terminal": true,
            "title": "Demo screen",
            "layout": {
              'type': "SingleColumnLayout",
              "children": [
                {
                  "type": "Footer",
                  "label": "Continue",
                  "on-click-action": {
                    "name": "complete",
                    "payload": {}
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}

