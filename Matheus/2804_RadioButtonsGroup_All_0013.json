                      "type": "string"
                    }
                  }
                },
                "__example__": [
                  {
                    "id": "1",
                    "title": "Online"
                  },
                  {
                    "id": "2",
                    "title": "In Person"
                  }
                ]
              }
            },
            "layout": {
              "type": "SingleColumnLayout",
              "children": [
                {
                  "type": "Form",
