{
  "prompt": {
    "EN": "Create a WhatsApp flow for scheduling an appointment. The flow should begin with a 'Basic Text' component consisting of a Heading, Subheading, Body, and Caption. Following the text, include a 'CalendarPicker' component that allows the user to select a preferred date for their consultation."
  },
  "ok_flows": [
    {
      "EN": {
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {},
  "screens": [
    {
      "id": "DEMO_SCREEN",
      "terminal": true,
      "title": "Demo screen",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
                  "type": "TextHeading",
                  "text": "Book Your Visit"
                },
                {
                  "type": "TextSubheading",
                  "text": "Check Specialist Availability"
                },
                {
                  "type": "TextBody",
                  "text": "We are excited to see you. Please pick a date from the calendar below that works best for your schedule."
                },
                {
                  "type": "TextCaption",
                  "text": "Appointments are subject to confirmation within 24 hours."
                }
                ,{
            "type": "CalendarPicker",
            "name": "calendar_range",
            "title": "Range calendar",
            "description": "Use this to select a date range",
            "label": {
              "start-date": "Start date",
              "end-date": "End date"
            },
            "helper-text": {
              "start-date": "Select from date",
              "end-date": "Select to date"
            },
            "required": {
              "start-date": true,
              "end-date": false
            },
            "mode": "range",
            "min-date": "2024-10-21",
            "max-date": "2025-12-12",
            "unavailable-dates": [
              "2024-11-28",
              "2024-11-01"
            ],
            "include-days": [
              "Mon",
              "Tue",
              "Wed",
              "Thu",
              "Fri"
            ],
            "min-days": 3,
            "max-days": 10,
            "init-value": {
              "start-date": "2024-10-22",
              "end-date": "2024-10-25"
            },
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "calendar_range": "${form.calendar_range}"
              }
            }
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {}
            }
          }
        ]
      }
    }
  ]
}
    }
  ],
  "ko_flows": [
    {
      "EN": {
        "version": "3.1",
        "screens": [
          {
            "id": "APPOINTMENT_SCREEN",
            "layout": {
              "type": "SingleColumnLayout",
              "children": [
                {
                  "type": "TextHeading",
                  "text": "Book Your Visit"
                },
                {
                  "type": "TextSubheading",
                  "text": "Check Specialist Availability"
                },
                {
                  "type": "TextBody",
                  "text": "We are excited to see you. Please pick a date from the calendar below that works best for your schedule."
                },
                {
                  "type": "TextCaption",
                  "text": "Appointments are subject to confirmation within 24 hours."
                },
                {
                  "type": "CalendarPicker",
                  "name": "selected_date",
                  "label": "Select a Date",
                  "required": true,
                  "min-date": "2026-04-25",
                  "max-date": "2026-05-25"
                },
                {
                  "type": "Footer",
                  "label": "Confirm Date",
                  "on-click-action": {
                    "name": "complete",
                    "payload": {
                      "appointment_date": "${data.wrong_variable_name}" 
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}