          ]
        },
        "screens": [
          {
            "id": "TOC",
            "data": {
              "text": {
                "type": "string",
                "__example__": "Your content"
              }
            },
            "title": "Terms of Service",
            "layout": {
              "type": "SingleColumnLayout",
              "children": [
                {
                  "type": "OrderedList",
                  "text": "${data.text}";
                }
              ]
            }
          },
          {
            "id": "FIRST_SCREEN",
            "title": "Welcome",
            "terminal": true,
            "layout": {
              "type": "SingleColumnLayout",
              "children": [
                {
                  "type": "OptIn",
                  "name": "toc",
                  "required": true,
                  "label": "Please accept our 'Terms and Conditions' before proceeding.",
                  "on-click-action": {
                    "name": "data_exchange",
                    "payload": {}
                  }
                },
                {
                  "type": "Footer",
                  "label": "Proceed",
                  "on-click-action": {
                    "name": "complete",
                    "payload": {}
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
