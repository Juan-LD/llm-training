{
  "prompt": {
    "EN": "Produce a WhatsApp Flow implementing a technical Terms-of-Service validation sequence, where the user must read a dynamic text payload and explicitly opt in before the system triggers a completion action."
  },
  "ok_flows": [
    {
      "EN": {
        "version": "7.3",
        "data_api_version": "3.0",
        "routing_model": {
          "TOC": [],
          "FIRST_SCREEN": [
            "TOC"
          ]
        },
        "screens": [
          {
            "id": "TOC",
            "data": {
              "text": {
                "type": "string",
                "__example__": "Your content"
              }
            },
            "title": "Terms of Service",
            "layout": {
              "type": "SingleColumnLayout",
              "children": [
                {
                  "type": "RichText",
                  "text": "${data.text}"
                }
              ]
            }
          },
          {
            "id": "FIRST_SCREEN",
            "title": "Welcome",
            "terminal": true,
            "layout": {
              "type": "SingleColumnLayout",
              "children": [
                {
                  "type": "OptIn",
                  "name": "toc",
                  "required": true,
                  "label": "Please accept our 'Terms and Conditions' before proceeding.",
                  "on-click-action": {
                    "name": "data_exchange",
                    "payload": {}
                  }
                },
                {
                  "type": "Footer",
                  "label": "Proceed",
                  "on-click-action": {
                    "name": "complete",
                    "payload": {}
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "ko_flows": [
    {
      "EN": {
        "version": "7.3",
        "data_api_version": "3.0",
        "routing_model": {
          "TOC SCREEN": [], 
          "FIRST_SCREEN": [
            "TOC SCREEN"
          ]
        },
        "screens": [
          {
            "id": "TOC SCREEN", 
            "data": {
              "text": {
                "type": "strin", 
                "__example__": "Your content"
              }
            },
            "title": "Terms of Service",
            "layout": {
              "type": "SingleColumnLayout",
              "children": [
                {
                  "type": "RichTex", 
                  "text": "${data.text}"
                }
              ]
            }
          },
          {
            "id": "FIRST SCREEN", 
            "title": "Welcome",
            "terminal": true,
            "layout": {
              "type": "SingleColumnLayout",
              "children": [
                {
                  "type": "OptIn",
                  "label": "Please accept our 'Terms and Conditions' before proceeding."
                },
                {
                  "type": "Footer"
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
