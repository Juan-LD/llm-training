{
    "prompt": {
        "EN": "Ask user to select their country of residence. Options: USA, Canada, UK, Germany, France, Japan. Use dropdown menu. Required."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Where do you live?"
                                        },
                                        {
                                            "data-source": [
                                                {"id": "0_USA", "title": "USA"},
                                                {"id": "1_Canada", "title": "Canada"},
                                                {"id": "2_UK", "title": "UK"},
                                                {"id": "3_Germany", "title": "Germany"},
                                                {"id": "4_France", "title": "France"},
                                                {"id": "5_Japan", "title": "Japan"}
                                            ],
                                            "label": "Select your country",
                                            "name": "country",
                                            "required": true,
                                            "type": "Dropdown"
                                        },
                                        {
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "country": "${form.country}"
                                                }
                                            },
                                            "type": "Footer"
                                        }
                                    ],
                                    "name": "flow_path",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Location"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
