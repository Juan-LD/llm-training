{
    "prompt": {
        "EN": "Build a newsletter subscription form. Email required (email input type). Checkbox group for interests (4 options). Optional opt-in for extra updates. Complete action. Use camelCase: subscriberEmail, interests, allowExtra."
    },
    "ok_flows": [
        {
            "EN": {
                "version": "7.3",
                "screens": [
                    {
                        "id": "NEWSLETTER_SCREEN",
                        "title": "Stay Updated",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "TextSubheading",
                                    "text": "Get aquarium news, events & special offers"
                                },
                                {
                                    "type": "Form",
                                    "name": "newsletterForm",
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "name": "email",
                                            "label": "Email address",
                                            "input-type": "email",
                                            "required": true
                                        },
                                        {
                                            "type": "CheckboxGroup",
                                            "name": "interests",
                                            "label": "Interested in",
                                            "data-source": [
                                                { "id": "events", "title": "Special events" },
                                                { "id": "discounts", "title": "Discounts & offers" },
                                                { "id": "education", "title": "Educational programs" },
                                                { "id": "animals", "title": "New animal arrivals" }
                                            ]
                                        },
                                        {
                                            "type": "OptIn",
                                            "name": "extra",
                                            "label": "Receive other extra updates"
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Subscribe",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "subscriberEmail": "${form.email}",
                                                    "interests": "${form.interests}",
                                                    "allowExtra": "${form.extra}"
                                                }
                                            }
                                        }
                                    ]
                                }
                            ]
                        },
                        "terminal": true
                    }
                ]
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "version": "7.3",
                "screens": [
                    {
                        "id": "SUBSCRIBE",
                        "title": "Newsletter",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "RadioButtonsGroup",
                                    "name": "emailChoice",
                                    "required": true,
                                    "data-source": [
                                        { "id": "yes", "title": "Yes" }
                                    ]
                                },
                                {
                                    "type": "Footer",
                                    "label": "Send",
                                    "on-click-action": {
                                        "name": "complete",
                                        "payload": { "sub": "${form.emailChoice}" }
                                    }
                                }
                            ]
                        },
                        "terminal": true
                    }
                ]
            }
        }
    ]
}
