{
    "prompt": {
        "EN": "Generate a one-screen newsletter subscription flow. Email input (required, email type). Checkbox group for interests (Special events, Discounts & offers, Educational programs, New animal arrivals). Opt-in for extra updates. Complete action submits email, interests, and opt-in. Use camelCase: subscriberEmail, interests, allowExtra."
    },
    "ok_flows": [
        {
            "EN": {
                "version": "7.3",
                "screens": [
                    {
                        "id": "NEWSLETTER_SCREEN",
                        "title": "Stay Updated",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "TextSubheading",
                                    "text": "Get aquarium news, events & special offers"
                                },
                                {
                                    "type": "Form",
                                    "name": "newsletterForm",
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "name": "email",
                                            "label": "Email address",
                                            "input-type": "email",
                                            "required": true
                                        },
                                        {
                                            "type": "CheckboxGroup",
                                            "name": "interests",
                                            "label": "Interested in",
                                            "data-source": [
                                                { "id": "events", "title": "Special events" },
                                                { "id": "discounts", "title": "Discounts & offers" },
                                                { "id": "education", "title": "Educational programs" },
                                                { "id": "animals", "title": "New animal arrivals" }
                                            ]
                                        },
                                        {
                                            "type": "OptIn",
                                            "name": "extra",
                                            "label": "Receive other extra updates"
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Subscribe",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "subscriberEmail": "${form.email}",
                                                    "interests": "${form.interests}",
                                                    "allowExtra": "${form.extra}"
                                                }
                                            }
                                        }
                                    ]
                                }
                            ]
                        },
                        "terminal": true
                    }
                ]
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "version": "7.2",
                "screens": [
                    {
                        "id": "NEWS",
                        "title": "Subscribe",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "TextInput",
                                    "name": "mail",
                                    "required": false,
                                    "input-type": "text"
                                },
                                {
                                    "type": "Footer",
                                    "label": "Go",
                                    "on-click-action": {
                                        "name": "submit",
                                        "payload": {}
                                    }
                                }
                            ]
                        },
                        "terminal": false
                    }
                ]
            }
        }
    ]
}
