{
    "prompt": {
        "EN": "Build a one-screen bank loan application form. Ask for loan amount (number), purpose (radio with 5 options), credit score (radio with 4 options). All required. Use camelCase: loanAmount, loanPurpose, creditScoreRange."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Taking out a bank loan"
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "How much money do you want to take out?"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "number",
                                            "label": "100",
                                            "name": "loanAmount",
                                            "required": true
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "For what purpose?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Loan purpose",
                                            "name": "loanPurpose",
                                            "required": true,
                                            "data-source": [
                                                { "id": "debtConsolidation", "title": "Debt consolidation" },
                                                { "id": "homeImprovement", "title": "Home improvement" },
                                                { "id": "medical", "title": "Medical" },
                                                { "id": "wedding", "title": "Wedding" },
                                                { "id": "other", "title": "Other" }
                                            ]
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "Credit score range?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Credit score range",
                                            "name": "creditScoreRange",
                                            "required": true,
                                            "data-source": [
                                                { "id": "score720plus", "title": "720+" },
                                                { "id": "score680to719", "title": "680 - 719" },
                                                { "id": "score640to679", "title": "640 - 679" },
                                                { "id": "score640minus", "title": "640-" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "loanAmount": "${form.loanAmount}",
                                                    "loanPurpose": "${form.loanPurpose}",
                                                    "creditScoreRange": "${form.creditScoreRange}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Loan Information"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "FIRST",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "input-type": "text",
                                            "name": "amountText",
                                            "required": false
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "go",
                                                "next": { "name": "RECOMMEND", "type": "screen" },
                                                "payload": {
                                                    "amountVal": "${form.amountText}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flow",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Amount",
                        "terminal": false
                    },
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "purpose",
                                            "required": false,
                                            "data-source": []
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "submit",
                                                "payload": {
                                                    "finalAmount": "${data.amountVal}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flow",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Purpose"
                    }
                ],
                "version": "7.2"
            }
        }
    ]
}
