{
  "prompt": {
    "EN": "Generate a work feedback flow. 2 screens. Screen 1: comfortable at work (Yes/No) + general mood (checkbox with 5 options). Screen 2: extra notes textarea required. Use camelCase: comfortableAtWork, generalMood, extraNotes. Navigate then complete. Include example data on screen 2."
  },
  "ok_flows": [
    {
      "EN": {
        "screens": [
          {
            "data": {},
            "id": "RECOMMEND",
            "layout": {
              "children": [
                {
                  "children": [
                    {
                      "type": "TextSubheading",
                      "text": "Do you feel comfortable at work?"
                    },
                    {
                      "type": "RadioButtonsGroup",
                      "label": "Yes or No",
                      "name": "comfortableAtWork",
                      "required": true,
                      "data-source": [
                        { "id": "yes", "title": "Yes" },
                        { "id": "no", "title": "No" }
                      ]
                    },
                    {
                      "type": "TextSubheading",
                      "text": "What is your general mood at work?"
                    },
                    {
                      "type": "CheckboxGroup",
                      "label": "Mood",
                      "name": "generalMood",
                      "required": true,
                      "data-source": [
                        { "id": "sleepy", "title": "Sleepy" },
                        { "id": "bored", "title": "Bored" },
                        { "id": "happy", "title": "Happy" },
                        { "id": "energized", "title": "Energized" },
                        { "id": "tired", "title": "Tired" }
                      ]
                    },
                    {
                      "type": "Footer",
                      "label": "Continue",
                      "on-click-action": {
                        "name": "navigate",
                        "next": { "name": "EXTRA_NOTES", "type": "screen" },
                        "payload": {
                          "comfortableAtWork": "${form.comfortableAtWork}",
                          "generalMood": "${form.generalMood}"
                        }
                      }
                    }
                  ],
                  "name": "flowPath",
                  "type": "Form"
                }
              ],
              "type": "SingleColumnLayout"
            },
            "title": "Work feedback"
          },
          {
            "data": {
              "comfortableAtWork": { "__example__": "yes", "type": "string" },
              "generalMood": { "__example__": ["happy"], "items": { "type": "string" }, "type": "array" }
            },
            "id": "EXTRA_NOTES",
            "layout": {
              "children": [
                {
                  "children": [
                    {
                      "type": "TextSubheading",
                      "text": "Extra Notes"
                    },
                    {
                      "type": "TextArea",
                      "label": "Write any notes here",
                      "name": "extraNotes",
                      "required": true
                    },
                    {
                      "type": "Footer",
                      "label": "Finish",
                      "on-click-action": {
                        "name": "complete",
                        "payload": {
                          "extraNotes": "${form.extraNotes}",
                          "comfortableAtWork": "${data.comfortableAtWork}",
                          "generalMood": "${data.generalMood}"
                        }
                      }
                    }
                  ],
                  "name": "flowPath",
                  "type": "Form"
                }
              ],
              "type": "SingleColumnLayout"
            },
            "terminal": true,
            "title": "Work feedback notes"
          }
        ],
        "version": "7.3"
      }
    }
  ],
  "ko_flows": [
    {
      "EN": {
        "screens": [
          {
            "data": {},
            "id": "STEP_ONE",
            "layout": {
              "children": [
                {
                  "children": [
                    {
                      "type": "RadioButtonsGroup",
                      "name": "comfortRadio",
                      "required": true,
                      "data-source": [
                        { "id": "yes", "title": "Yes" }
                      ]
                    },
                    {
                      "type": "Footer",
                      "label": "Next",
                      "on-click-action": {
                        "name": "navigate",
                        "next": { "name": "STEP_TWO", "type": "screen" },
                        "payload": {
                          "comfortValue": "${form.comfortRadio}"
                        }
                      }
                    }
                  ],
                  "name": "f1",
                  "type": "Form"
                }
              ],
              "type": "SingleColumnLayout"
            },
            "title": "Comfort",
            "terminal": false
          },
          {
            "data": {},
            "id": "STEP_TWO",
            "layout": {
              "children": [
                {
                  "children": [
                    {
                      "type": "TextArea",
                      "name": "notesArea",
                      "required": false
                    },
                    {
                      "type": "Footer",
                      "label": "Finish",
                      "on-click-action": {
                        "name": "complete",
                        "payload": {
                          "finalComfort": "${data.comfortValue}",
                          "finalNotes": "${form.notesArea}"
                        }
                      }
                    }
                  ],
                  "name": "f2",
                  "type": "Form"
                }
              ],
              "type": "SingleColumnLayout"
            },
            "terminal": true,
            "title": "Notes"
          }
        ],
        "version": "7.3"
      }
    }
  ]
}
