{
    "prompt": {
        "EN": "Make a 2-screen mortgage approval form. First screen: property type (radio with 5 options) and purchase price (text). Second screen: purchase experience dropdown and customer service dropdown (both 5-star scale). Use camelCase. Navigate on first, complete on second."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "What is the type of your property?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Type of property",
                                            "name": "propertyType",
                                            "required": true,
                                            "data-source": [
                                                { "id": "singleFamily", "title": "Single Family" },
                                                { "id": "condo", "title": "Condo" },
                                                { "id": "townhouse", "title": "Townhouse" },
                                                { "id": "multiFamily", "title": "Multi-family" },
                                                { "id": "land", "title": "Land" }
                                            ]
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "Estimated purchase price"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "text",
                                            "label": "Purchase price",
                                            "name": "purchasePrice",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Continue",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "RATE", "type": "screen" },
                                                "payload": {
                                                    "propertyType": "${form.propertyType}",
                                                    "purchasePrice": "${form.purchasePrice}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Mortgage Approval"
                    },
                    {
                        "data": {
                            "propertyType": { "__example__": "singleFamily", "type": "string" },
                            "purchasePrice": { "__example__": "250000", "type": "string" }
                        },
                        "id": "RATE",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Rate the following: "
                                        },
                                        {
                                            "type": "Dropdown",
                                            "label": "Purchase experience",
                                            "required": true,
                                            "name": "purchaseExperience",
                                            "data-source": [
                                                { "id": "excellent", "title": "★★★★★ • Excellent (5/5)" },
                                                { "id": "good", "title": "★★★★☆ • Good (4/5)" },
                                                { "id": "average", "title": "★★★☆☆ • Average (3/5)" },
                                                { "id": "poor", "title": "★★☆☆☆ • Poor (2/5)" },
                                                { "id": "veryPoor", "title": "★☆☆☆☆ • Very Poor (1/5)" }
                                            ]
                                        },
                                        {
                                            "type": "Dropdown",
                                            "label": "Customer service",
                                            "required": true,
                                            "name": "customerService",
                                            "data-source": [
                                                { "id": "excellent", "title": "★★★★★ • Excellent (5/5)" },
                                                { "id": "good", "title": "★★★★☆ • Good (4/5)" },
                                                { "id": "average", "title": "★★★☆☆ • Average (3/5)" },
                                                { "id": "poor", "title": "★★☆☆☆ • Poor (2/5)" },
                                                { "id": "veryPoor", "title": "★☆☆☆☆ • Very Poor (1/5)" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Done",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "purchaseExperience": "${form.purchaseExperience}",
                                                    "customerService": "${form.customerService}",
                                                    "propertyType": "${data.propertyType}",
                                                    "purchasePrice": "${data.purchasePrice}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Purchase evaluation"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "FIRST_PAGE",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "Dropdown",
                                            "name": "typeDrop",
                                            "required": true,
                                            "data-source": [
                                                { "id": "sf", "title": "Single Family" },
                                                { "id": "condo", "title": "Condo" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "RATE", "type": "screen" },
                                                "payload": {
                                                    "typeChoice": "${form.typeDrop}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "formA",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Type",
                        "terminal": false
                    },
                    {
                        "data": {},
                        "id": "RATE",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "name": "priceText",
                                            "required": false
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "finalType": "${data.typeChoice}",
                                                    "finalPrice": "${form.priceText}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "formB",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Price"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
