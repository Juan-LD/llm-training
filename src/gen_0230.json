{
    "prompt": {
        "EN": "Make a 3-screen lost pet WhatsApp flow. Screen 1: pet breed (text), pet name (text), last seen location (textarea). Screen 2: has microchip? (yes/no), offer reward? (yes/no). Screen 3: any other details? (textarea, optional). Use SingleColumnLayout, navigate, complete. Field names: petBreed, petName, lastSeenLocation, hasMicrochip, offerReward, additionalNotes."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Whats the pet breed?"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "text",
                                            "label": "Pet breed",
                                            "name": "petBreed",
                                            "required": true
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "What about its name?"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "text",
                                            "label": "Pet name",
                                            "name": "petName",
                                            "required": true
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "And the last seen location?"
                                        },
                                        {
                                            "type": "TextArea",
                                            "label": "Pet location",
                                            "name": "lastSeenLocation",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Continue",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "MORE_INFO", "type": "screen" },
                                                "payload": {
                                                    "petBreed": "${form.petBreed}",
                                                    "petName": "${form.petName}",
                                                    "lastSeenLocation": "${form.lastSeenLocation}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Pet information"
                    },
                    {
                        "data": {
                            "petBreed": { "__example__": "Golden Retriever", "type": "string" },
                            "petName": { "__example__": "Max", "type": "string" },
                            "lastSeenLocation": { "__example__": "Central Park", "type": "string" }
                        },
                        "id": "MORE_INFO",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Does it have a microchip?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Yes or No",
                                            "name": "hasMicrochip",
                                            "required": true,
                                            "data-source": [
                                                { "id": "yes", "title": "Yes" },
                                                { "id": "no", "title": "No" }
                                            ]
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "Offer reward?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Yes or No",
                                            "name": "offerReward",
                                            "required": true,
                                            "data-source": [
                                                { "id": "yes", "title": "Yes" },
                                                { "id": "no", "title": "No" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Continue",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "FINAL_NOTES", "type": "screen" },
                                                "payload": {
                                                    "hasMicrochip": "${form.hasMicrochip}",
                                                    "offerReward": "${form.offerReward}",
                                                    "petBreed": "${data.petBreed}",
                                                    "petName": "${data.petName}",
                                                    "lastSeenLocation": "${data.lastSeenLocation}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "More information"
                    },
                    {
                        "data": {
                            "hasMicrochip": { "__example__": "yes", "type": "string" },
                            "offerReward": { "__example__": "no", "type": "string" },
                            "petBreed": { "__example__": "Golden Retriever", "type": "string" },
                            "petName": { "__example__": "Max", "type": "string" },
                            "lastSeenLocation": { "__example__": "Central Park", "type": "string" }
                        },
                        "id": "FINAL_NOTES",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Anything important to mention?"
                                        },
                                        {
                                            "type": "TextArea",
                                            "label": "Additional Notes",
                                            "name": "additionalNotes",
                                            "required": false
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "additionalNotes": "${form.additionalNotes}",
                                                    "hasMicrochip": "${data.hasMicrochip}",
                                                    "offerReward": "${data.offerReward}",
                                                    "petBreed": "${data.petBreed}",
                                                    "petName": "${data.petName}",
                                                    "lastSeenLocation": "${data.lastSeenLocation}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Final notes"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "START",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "name": "petBreed",
                                            "required": true
                                        },
                                        {
                                            "type": "TextInput",
                                            "name": "petName",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "MIDDLE", "type": "screen" },
                                                "payload": {
                                                    "breed": "${form.petBreed}",
                                                    "name": "${form.petName}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "p",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Pet"
                    },
                    {
                        "data": {},
                        "id": "MIDDLE",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextArea",
                                            "name": "location",
                                            "required": true
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "microchip",
                                            "required": true,
                                            "data-source": [
                                                { "id": "yes", "title": "Yes" },
                                                { "id": "no", "title": "No" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "END", "type": "screen" },
                                                "payload": {
                                                    "loc": "${form.location}",
                                                    "chip": "${form.microchip}",
                                                    "breedData": "${data.breed}",
                                                    "nameData": "${data.name}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "p",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Location & Chip"
                    },
                    {
                        "data": {},
                        "id": "END",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "reward",
                                            "required": true,
                                            "data-source": [
                                                { "id": "no", "title": "No" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "finalBreed": "${data.breedData}",
                                                    "finalName": "${data.nameData}",
                                                    "finalLoc": "${data.loc}",
                                                    "finalChip": "${data.chip}",
                                                    "finalReward": "${form.reward}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "p",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": false,
                        "title": "Reward"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
