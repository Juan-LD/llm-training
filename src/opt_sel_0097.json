{
    "prompt": {
        "EN": "Maintenance flow. First screen ask address and issue type. Second screen ask urgency and record problem. Don't bother putting example data on second screen, just leave it empty. The payload will figure it out."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Type your address"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "text",
                                            "label": "John Doe 215 S ...",
                                            "name": "address",
                                            "required": true
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "What type of issue is it?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Issue type",
                                            "name": "issueType",
                                            "required": true,
                                            "data-source": [
                                                { "id": "plumbing", "title": "Plumbing" },
                                                { "id": "electrical", "title": "Electrical" },
                                                { "id": "hvac", "title": "HVAC" },
                                                { "id": "appliance", "title": "Appliance" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Continue",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "RATE", "type": "screen" },
                                                "payload": {
                                                    "address": "${form.address}",
                                                    "issueType": "${form.issueType}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Issue general problem"
                    },
                    {
                        "data": {
                            "address": { "__example__": "123 Main St", "type": "string" },
                            "issueType": { "__example__": "plumbing", "type": "string" }
                        },
                        "id": "RATE",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Select how much this problem needs to be fixed."
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Urgency level",
                                            "name": "urgencyLevel",
                                            "required": true,
                                            "data-source": [
                                                { "id": "emergency", "title": "Emergency" },
                                                { "id": "soon", "title": "Soon" },
                                                { "id": "schedule", "title": "Schedule" }
                                            ]
                                        },
                                        {
                                            "type": "OptIn",
                                            "label": "Record this problem",
                                            "name": "recordProblem",
                                            "required": false
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Done",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "urgencyLevel": "${form.urgencyLevel}",
                                                    "recordProblem": "${form.recordProblem}",
                                                    "address": "${data.address}",
                                                    "issueType": "${data.issueType}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Specific problem information"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "name": "fullAddress",
                                            "required": true
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "problemType",
                                            "required": true,
                                            "data-source": [
                                                { "id": "pl", "title": "Plumbing" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Continue",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "RATE", "type": "screen" },
                                                "payload": {
                                                    "addressCopy": "${form.fullAddress}",
                                                    "issueCopy": "${form.problemType}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "First"
                    },
                    {
                        "data": {},
                        "id": "RATE",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "urgency",
                                            "required": true,
                                            "data-source": [
                                                { "id": "e", "title": "Emergency" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Done",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "finalAddress": "${data.addressCopy}",
                                                    "finalIssue": "${data.issueCopy}",
                                                    "finalUrgency": "${form.urgency}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Second"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
