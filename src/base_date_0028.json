{
    "prompt": {
        "EN": "Ask for preferred delivery date. Use date picker. No manual typing. Date selection is required."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Choose your delivery date"
                                        },
                                        {
                                            "label": "Select",
                                            "name": "deliveryDate",
                                            "required": true,
                                            "type": "DatePicker"
                                        },
                                        {
                                            "label": "Confirm",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "deliveryDate": "${form.deliveryDate}"
                                                }
                                            },
                                            "type": "Footer"
                                        }
                                    ],
                                    "name": "flow_path",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Delivery"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "What's your mother's maiden name?"
                                        },
                                        {
                                            "label": "Select",
                                            "name": "mothersMaidenName",
                                            "required": true,
                                            "type": "DatePicker"
                                        },
                                        {
                                            "label": "Confirm",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "deliveryDate": "${form.mothersMaidenName}"
                                                }
                                            },
                                            "type": "Footer"
                                        }
                                    ],
                                    "name": "flow_path",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Security Question"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
