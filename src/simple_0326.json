{
    "prompt": {
        "EN": "Create an order rescheduling survey. One screen. Heading: 'Your order did not arrive! Please mark another day here.' Date picker required. Complete action. Use camelCase: newDeliveryDate."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Your order did not arrive! Please mark another day here."
                                        },
                                        {
                                            "type": "DatePicker",
                                            "label": "Select new delivery date",
                                            "name": "newDeliveryDate",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "newDeliveryDate": "${form.newDeliveryDate}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Order didnt arrive!"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "FIRST",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "name": "customDate",
                                            "required": true,
                                            "input-type": "text"
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "RECOMMEND", "type": "screen" },
                                                "payload": {
                                                    "dateText": "${form.customDate}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "p",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Date",
                        "terminal": false
                    },
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "DatePicker",
                                            "name": "confirmDate",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "finalDateText": "${data.dateText}",
                                                    "finalDate": "${form.confirmDate}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "p",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": false,
                        "title": "Confirm"
                    }
                ],
                "version": "7.0"
            }
        }
    ]
}
