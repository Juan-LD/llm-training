{
    "prompt": {
        "EN": "Generate a 1-screen exit interview flow. Ask primary reason for leaving (radio: Money, Growth, Management, Culture, Relocation, Other) and what could have kept them (checkbox: Better salary, Better ambience, Less work, More bonuses). Both required. Complete submits both fields. Use camelCase: primaryReason, retentionFactors."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "We are sorry to see you go. Please answer this form for your reasons."
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "What was the primary reason for leaving?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Why?",
                                            "name": "primaryReason",
                                            "required": true,
                                            "data-source": [
                                                { "id": "money", "title": "Money" },
                                                { "id": "growth", "title": "Growth" },
                                                { "id": "management", "title": "Management" },
                                                { "id": "culture", "title": "Culture" },
                                                { "id": "relocation", "title": "Relocation" },
                                                { "id": "other", "title": "Other" }
                                            ]
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "What could have kept you from leaving?"
                                        },
                                        {
                                            "type": "CheckboxGroup",
                                            "label": "What?",
                                            "name": "retentionFactors",
                                            "required": true,
                                            "data-source": [
                                                { "id": "betterSalary", "title": "Better salary" },
                                                { "id": "betterAmbience", "title": "Better ambience" },
                                                { "id": "lessWork", "title": "Less work" },
                                                { "id": "moreBonuses", "title": "More bonuses" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "primaryReason": "${form.primaryReason}",
                                                    "retentionFactors": "${form.retentionFactors}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Reason of leave"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "reason",
                                            "required": true,
                                            "data-source": [
                                                { "id": "money", "title": "Money" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Submit",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "onlyReason": "${form.reason}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Exit"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
