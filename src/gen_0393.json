{
    "prompt": {
        "EN": "Create a one-screen aquarium feedback survey. Rating dropdown required (5 options from Excellent to Very Poor). Optional comments textarea (max 200 chars, helper text). Complete action. Use camelCase field names."
    },
    "ok_flows": [
        {
            "EN": {
                "version": "7.3",
                "screens": [
                    {
                        "id": "FEEDBACK_SCREEN",
                        "title": "Rate Your Visit",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "TextSubheading",
                                    "text": "How was your experience at the aquarium?"
                                },
                                {
                                    "type": "Form",
                                    "name": "feedbackForm",
                                    "children": [
                                        {
                                            "type": "Dropdown",
                                            "label": "Overall experience",
                                            "required": true,
                                            "name": "rating",
                                            "data-source": [
                                                { "id": "excellent", "title": "★★★★★ • Excellent (5/5)" },
                                                { "id": "good", "title": "★★★★☆ • Good (4/5)" },
                                                { "id": "average", "title": "★★★☆☆ • Average (3/5)" },
                                                { "id": "poor", "title": "★★☆☆☆ • Poor (2/5)" },
                                                { "id": "veryPoor", "title": "★☆☆☆☆ • Very Poor (1/5)" }
                                            ]
                                        },
                                        {
                                            "type": "TextArea",
                                            "name": "comments",
                                            "label": "Any comments?",
                                            "max-length": 200,
                                            "helper-text": "Tell us what you loved or how we can improve"
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Submit Feedback",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "rating": "${form.rating}",
                                                    "comments": "${form.comments}"
                                                }
                                            }
                                        }
                                    ]
                                }
                            ]
                        },
                        "terminal": true
                    }
                ]
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "version": "7.3",
                "screens": [
                    {
                        "id": "PAGE1",
                        "title": "Feedback",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "Dropdown",
                                    "name": "experience",
                                    "required": true,
                                    "data-source": [
                                        { "id": "excellent", "title": "Excellent" },
                                        { "id": "good", "title": "Good" }
                                    ]
                                },
                                {
                                    "type": "TextArea",
                                    "name": "commentField",
                                    "required": true,
                                    "max-length": 50
                                },
                                {
                                    "type": "Footer",
                                    "label": "Next",
                                    "on-click-action": {
                                        "name": "navigate",
                                        "next": { "name": "THANKS", "type": "screen" },
                                        "payload": { "exp": "${form.experience}", "cmt": "${form.commentField}" }
                                    }
                                }
                            ]
                        },
                        "terminal": false
                    },
                    {
                        "id": "THANKS",
                        "title": "Thank You",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "Footer",
                                    "label": "Done",
                                    "on-click-action": {
                                        "name": "complete",
                                        "payload": { "finalExp": "${data.exp}", "finalCmt": "${data.cmt}" }
                                    }
                                }
                            ]
                        },
                        "terminal": true
                    }
                ]
            }
        }
    ]
}
