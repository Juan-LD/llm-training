{
    "prompt": {
        "EN": "Flight ID with a dropdown of options: AA123, BA456, DL789. Required."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Whats the flight ID?"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "text",
                                            "label": "Type flight id here",
                                            "name": "flightId",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Continue",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "flightId": "${form.flightId}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Check flight"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "Dropdown",
                                            "name": "flightSelect",
                                            "required": true,
                                            "data-source": [
                                                { "id": "AA123", "title": "AA123" },
                                                { "id": "BA456", "title": "BA456" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Go",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "flight": "${form.flightSelect}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Select Flight"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
