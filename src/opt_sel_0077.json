                                                }
                                            ]
                                        },
                                        {
                                            "type": "Dropdown",
                                            "label": "Customer service",
                                            "required": true,
                                            "name": "customerService",
                                            "data-source": [
                                                {
                                                    "id": "excellent",
                                                    "title": "★★★★★ • Excellent (5/5)"
                                                },
                                                {
                                                    "id": "good",
                                                    "title": "★★★★☆ • Good (4/5)"
                                                },
                                                {
                                                    "id": "average",
