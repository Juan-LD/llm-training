                                                    "purchaseExperienceRating": "${form.purchaseExperience}",
                                                    "deliveryAndSetupRating": "${form.deliveryAndSetup}",
                                                    "customerServiceRating": "${form.customerService}",
                                                    "selectedDishType": "${data.selectedDishType}",
                                                    "specialInstructions": "${data.specialInstructions}"
                                                }
                                            },
                                            "type": "Footer"
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
