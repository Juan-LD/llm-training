{
    "prompt": {
        "EN": "Collect customer's date of birth. Date picker only. Cannot proceed without valid date selection."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "When were you born?"
                                        },
                                        {
                                            "label": "Select date",
                                            "name": "dob",
                                            "required": true,
                                            "type": "DatePicker"
                                        },
                                        {
                                            "label": "Submit",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "dob": "${form.dob}"
                                                }
                                            },
                                            "type": "Footer"
                                        }
                                    ],
                                    "name": "flow_path",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Date of Birth"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "When were you born?"
                                        },
                                        {
                                            "type": "TextArea",
                                            "label": "Type your favorite animal",
                                            "required": true,
                                            "name": "favoriteAnimal"
                                        },
                                        {
                                            "label": "Submit",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "dob": "${form.favoriteAnimal}"
                                                }
                                            },
                                            "type": "Footer"
                                        }
                                    ],
                                    "name": "flow_path",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Favorite Animal"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
