{
    "prompt": {
        "EN": "Two screens. First screen asks which trees they saw (checkbox, multiple). Second screen asks if park was up to standards (Yes/No) and has an optional comments box."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "What kind of trees did you see in your local park?"
                                        },
                                        {
                                            "type": "CheckboxGroup",
                                            "label": "Tree species",
                                            "name": "treeSpecies",
                                            "required": true,
                                            "data-source": [
                                                { "id": "birch", "title": "Birch" },
                                                { "id": "acacia", "title": "Acacia" },
                                                { "id": "maple", "title": "Maple" },
                                                { "id": "spruce", "title": "Spruce" },
                                                { "id": "pine", "title": "Pine" },
                                                { "id": "willow", "title": "Willow" },
                                                { "id": "oak", "title": "Oak" }
                                            ]
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "Was the park up to standards?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Yes or No",
                                            "name": "parkUpToStandards",
                                            "required": true,
                                            "data-source": [
                                                { "id": "yes", "title": "Yes" },
                                                { "id": "no", "title": "No" }
                                            ]
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "Any additional comments?"
                                        },
                                        {
                                            "type": "TextArea",
                                            "label": "Notes",
                                            "name": "additionalComments",
                                            "required": false
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Submit",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "treeSpecies": "${form.treeSpecies}",
                                                    "parkUpToStandards": "${form.parkUpToStandards}",
                                                    "additionalComments": "${form.additionalComments}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Park trees"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "screens": [
                {
                    "data": {},
                    "id": "TREES",
                    "layout": {
                        "children": [
                            {
                                "children": [
                                    {
                                        "type": "CheckboxGroup",
                                        "name": "treeSpecies",
                                        "required": true,
                                        "data-source": [
                                            { "id": "birch", "title": "Birch" }
                                        ]
                                    },
                                    {
                                        "type": "Footer",
                                        "label": "Next",
                                        "on-click-action": {
                                            "name": "navigate",
                                            "next": { "name": "STANDARDS", "type": "screen" },
                                            "payload": {
                                                "selectedTrees": "${form.treeSpecies}"
                                            }
                                        }
                                    }
                                ],
                                "name": "flowPath",
                                "type": "Form"
                            }
                        ],
                        "type": "SingleColumnLayout"
                    },
                    "title": "Trees"
                },
                {
                    "data": {},
                    "id": "STANDARDS",
                    "layout": {
                        "children": [
                            {
                                "children": [
                                    {
                                        "type": "RadioButtonsGroup",
                                        "name": "parkStandards",
                                        "required": true,
                                        "data-source": [
                                            { "id": "yes", "title": "Yes" }
                                        ]
                                    },
                                    {
                                        "type": "Footer",
                                        "label": "Done",
                                        "on-click-action": {
                                            "name": "complete",
                                            "payload": {
                                                "trees": "${data.selectedTrees}",
                                                "standard": "${form.parkStandards}"
                                            }
                                        }
                                    }
                                ],
                                "name": "flowPath",
                                "type": "Form"
                            }
                        ],
                        "type": "SingleColumnLayout"
                    },
                    "terminal": true,
                    "title": "Standards"
                }
            ],
            "version": "7.3"
        }
    ]
}
