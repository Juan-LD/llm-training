{
    "prompt": {
        "EN": "Generate a one-screen order rescheduling flow. Text heading: 'Your order did not arrive! Please mark another day here.' Date picker required. Complete action submits the selected date. Use camelCase: newDeliveryDate."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Your order did not arrive! Please mark another day here."
                                        },
                                        {
                                            "type": "DatePicker",
                                            "label": "Select new delivery date",
                                            "name": "newDeliveryDate",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "newDeliveryDate": "${form.newDeliveryDate}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Order didnt arrive!"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "DatePicker",
                                            "name": "date",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Submit",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "onlyDate": "${form.date}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Reschedule"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
