{
    "prompt": {
        "EN": "Create a one-screen price suggestion flow. Heading: 'What price should the hotdog be?' Number input for price (required). Complete action. Use camelCase: suggestedPrice."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "What price should the hotdog be?"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "number",
                                            "label": "12,34",
                                            "name": "suggestedPrice",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Register",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "suggestedPrice": "${form.suggestedPrice}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Suggest price change"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "A",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Enter price"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "number",
                                            "name": "priceField",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "RECOMMEND", "type": "screen" },
                                                "payload": {
                                                    "priceVal": "${form.priceField}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "formX",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Price",
                        "terminal": false
                    },
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "OptIn",
                                            "name": "agreeOpt",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "finalPrice": "${data.priceVal}",
                                                    "finalAgree": "${form.agreeOpt}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "formY",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": false,
                        "title": "Agreement"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
