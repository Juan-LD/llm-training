{
    "prompt": {
        "EN": "Make a one-screen work absence justification form. Dropdown for reason (4 options). Radio for vacation/salary. Both required. Use camelCase. Complete action."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Youre not going to work today? Why?"
                                        },
                                        {
                                            "type": "Dropdown",
                                            "label": "No work today due to",
                                            "name": "absenceReason",
                                            "required": true,
                                            "data-source": [
                                                { "id": "beingSick", "title": "Being sick" },
                                                { "id": "feelingTired", "title": "Feeling tired" },
                                                { "id": "otherResponsibilities", "title": "Other responsibilities" },
                                                { "id": "other", "title": "Other" }
                                            ]
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Mark as vacation day?",
                                            "name": "markAsVacation",
                                            "required": true,
                                            "data-source": [
                                                { "id": "vacationDay", "title": "Mark as a vacation day" },
                                                { "id": "deductFromSalary", "title": "Take away from salary" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "absenceReason": "${form.absenceReason}",
                                                    "markAsVacation": "${form.markAsVacation}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Skipping working justification"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "FIRST_PAGE",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "vacationRadio",
                                            "required": true,
                                            "data-source": [
                                                { "id": "deduct", "title": "Deduct" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "RECOMMEND", "type": "screen" },
                                                "payload": {
                                                    "vacationChoice": "${form.vacationRadio}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "formA",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Vacation",
                        "terminal": false
                    },
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "Dropdown",
                                            "name": "reasonDrop",
                                            "required": false,
                                            "data-source": [
                                                { "id": "other", "title": "Other" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "finalVacation": "${data.vacationChoice}",
                                                    "finalReason": "${form.reasonDrop}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "formB",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Reason"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
