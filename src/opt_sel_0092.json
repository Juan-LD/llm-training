{
    "prompt": {
        "EN": "Actually we only need one screen. Just ask for name and guest count and dishes all on the same screen. No second screen. Submit all at once. Make it work."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Type your name"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "text",
                                            "label": "First and last name",
                                            "name": "firstNameAndLastName",
                                            "required": true
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "How many guests will be there?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Number of guests",
                                            "name": "numberOfGuests",
                                            "required": true,
                                            "data-source": [
                                                { "id": "1", "title": "1" },
                                                { "id": "2", "title": "2" },
                                                { "id": "3", "title": "3" },
                                                { "id": "4", "title": "4" },
                                                { "id": "5", "title": "5" },
                                                { "id": "5plus", "title": "5 +" }
                                            ]
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "Type your email for the booking confirmation"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "email",
                                            "label": "example@example.com",
                                            "name": "email",
                                            "required": true
                                        },
                                        {
                                            "type": "OptIn",
                                            "label": "Suggest places to visit and dine during my stay.",
                                            "name": "suggestPlaces",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Continue",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "RATE", "type": "screen" },
                                                "payload": {
                                                    "firstNameAndLastName": "${form.firstNameAndLastName}",
                                                    "numberOfGuests": "${form.numberOfGuests}",
                                                    "email": "${form.email}",
                                                    "suggestPlaces": "${form.suggestPlaces}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Booking Information"
                    },
                    {
                        "data": {
                            "firstNameAndLastName": { "__example__": "John Doe", "type": "string" },
                            "numberOfGuests": { "__example__": "2", "type": "string" },
                            "email": { "__example__": "john@example.com", "type": "string" },
                            "suggestPlaces": { "__example__": true, "type": "boolean" }
                        },
                        "id": "RATE",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Meal preferences for the stay"
                                        },
                                        {
                                            "type": "CheckboxGroup",
                                            "label": "Select multiple dishes",
                                            "name": "selectedDishes",
                                            "required": true,
                                            "data-source": [
                                                { "id": "grilledSalmon", "title": "Grilled Salmon" },
                                                { "id": "roastedChicken", "title": "Roasted Chicken" },
                                                { "id": "beefTenderloin", "title": "Beef Tenderloin" },
                                                { "id": "mushroomRisotto", "title": "Mushroom Risotto (Vegetarian)" },
                                                { "id": "veganBowl", "title": "Vegan Bowl" },
                                                { "id": "kidsTenders", "title": "Kids: Chicken Tenders" },
                                                { "id": "kidsMacCheese", "title": "Kids: Mac & Cheese" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Done",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "selectedDishes": "${form.selectedDishes}",
                                                    "firstNameAndLastName": "${data.firstNameAndLastName}",
                                                    "numberOfGuests": "${data.numberOfGuests}",
                                                    "email": "${data.email}",
                                                    "suggestPlaces": "${data.suggestPlaces}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Booking extra information"
                    }
                ],
                "version": "7.3"
            }

        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "name": "fullName",
                                            "required": true
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "guestCount",
                                            "required": true,
                                            "data-source": [
                                                { "id": "1", "title": "1" },
                                                { "id": "2", "title": "2" }
                                            ]
                                        },
                                        {
                                            "type": "CheckboxGroup",
                                            "name": "selectedDishes",
                                            "required": true,
                                            "data-source": [
                                                { "id": "fish", "title": "Fish" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Submit",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "person": "${form.fullName}",
                                                    "guests": "${form.guestCount}",
                                                    "dishes": "${form.selectedDishes}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Booking"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
