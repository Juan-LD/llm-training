{
    "prompt": {
        "EN": "Flight ID form. Use a radio button group with options 'Domestic' and 'International' instead of text input."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Whats the flight ID?"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "text",
                                            "label": "Type flight id here",
                                            "name": "flightId",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Continue",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "flightId": "${form.flightId}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Check flight"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "flightType",
                                            "required": true,
                                            "data-source": [
                                                { "id": "domestic", "title": "Domestic" },
                                                { "id": "international", "title": "International" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Continue",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "type": "${form.flightType}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Flight Type"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
