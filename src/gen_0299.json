{
    "prompt": {
        "EN": "Generate a new employee check-in flow. 2 screens. Screen 1: feeling (radio: Good, Okay, Bad) + expectations met (radio: Yes, No). Screen 2: suggestions (textarea required) + extra notes (textarea required). Use camelCase field names. Navigate then complete. Include example data on screen 2."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "One month! Wow!"
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "How are you feeling after one month working here?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "How do you feel?",
                                            "name": "currentFeeling",
                                            "required": true,
                                            "data-source": [
                                                { "id": "good", "title": "Good" },
                                                { "id": "okay", "title": "Okay" },
                                                { "id": "bad", "title": "Bad" }
                                            ]
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "Has the company met with your needs and expectations?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Has it?",
                                            "name": "expectationsMet",
                                            "required": true,
                                            "data-source": [
                                                { "id": "yes", "title": "Yes" },
                                                { "id": "no", "title": "No" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Continue to Notes",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "EXTRA_NOTES", "type": "screen" },
                                                "payload": {
                                                    "currentFeeling": "${form.currentFeeling}",
                                                    "expectationsMet": "${form.expectationsMet}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Check up on new employee"
                    },
                    {
                        "data": {
                            "currentFeeling": { "__example__": "good", "type": "string" },
                            "expectationsMet": { "__example__": "yes", "type": "string" }
                        },
                        "id": "EXTRA_NOTES",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Now for any notes or suggestions you want to leave."
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "Any suggestions you want to leave?"
                                        },
                                        {
                                            "type": "TextArea",
                                            "label": "Leave suggestions",
                                            "name": "suggestions",
                                            "required": true
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "Any extra notes (eg. workplace problem or anything you personally want to note)"
                                        },
                                        {
                                            "type": "TextArea",
                                            "label": "Type any troubles",
                                            "name": "extraNotes",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Submit",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "suggestions": "${form.suggestions}",
                                                    "extraNotes": "${form.extraNotes}",
                                                    "currentFeeling": "${data.currentFeeling}",
                                                    "expectationsMet": "${data.expectationsMet}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Extra information"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "STEP_ONE",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "feelingRadio",
                                            "required": true,
                                            "data-source": [
                                                { "id": "good", "title": "Good" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "EXTRA_NOTES", "type": "screen" },
                                                "payload": {
                                                    "feelVal": "${form.feelingRadio}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "f1",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Feeling",
                        "terminal": false
                    },
                    {
                        "data": {},
                        "id": "EXTRA_NOTES",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextArea",
                                            "name": "notesArea",
                                            "required": false
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "finalFeeling": "${data.feelVal}",
                                                    "finalNotes": "${form.notesArea}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "f2",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Notes"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
