{
    "prompt": {
        "EN": "Create a bank loan application survey. One screen. Loan amount (number), purpose (5 radio options), credit score range (4 radio options). All required. Use camelCase."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Taking out a bank loan"
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "How much money do you want to take out?"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "number",
                                            "label": "100",
                                            "name": "loanAmount",
                                            "required": true
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "For what purpose?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Loan purpose",
                                            "name": "loanPurpose",
                                            "required": true,
                                            "data-source": [
                                                { "id": "debtConsolidation", "title": "Debt consolidation" },
                                                { "id": "homeImprovement", "title": "Home improvement" },
                                                { "id": "medical", "title": "Medical" },
                                                { "id": "wedding", "title": "Wedding" },
                                                { "id": "other", "title": "Other" }
                                            ]
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "Credit score range?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Credit score range",
                                            "name": "creditScoreRange",
                                            "required": true,
                                            "data-source": [
                                                { "id": "score720plus", "title": "720+" },
                                                { "id": "score680to719", "title": "680 - 719" },
                                                { "id": "score640to679", "title": "640 - 679" },
                                                { "id": "score640minus", "title": "640-" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "loanAmount": "${form.loanAmount}",
                                                    "loanPurpose": "${form.loanPurpose}",
                                                    "creditScoreRange": "${form.creditScoreRange}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Loan Information"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "FIRST",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "input-type": "email",
                                            "name": "customAmount",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "RECOMMEND", "type": "screen" },
                                                "payload": {
                                                    "amountText": "${form.customAmount}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "p",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Amount",
                        "terminal": false
                    },
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "purposeRadio",
                                            "required": true,
                                            "data-source": [
                                                { "id": "debt", "title": "Debt" },
                                                { "id": "home", "title": "Home" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "finalAmount": "${data.amountText}",
                                                    "finalPurpose": "${form.purposeRadio}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "p",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": false,
                        "title": "Purpose"
                    }
                ],
                "version": "7.0"
            }
        }
    ]
}
