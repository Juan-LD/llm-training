                                                {"id": "1_Bachelors", "title": "Bachelor's"},
                                                {"id": "2_Masters", "title": "Master's"},
                                                {"id": "3_PhD", "title": "PhD"},
                                                {"id": "4_Other", "title": "Other"}
                                            ],
                                            "label": "Degree",
                                            "name": "eduLevel",
