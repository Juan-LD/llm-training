{
    "prompt": {
        "EN": "Collect user's educational background. Options: High School, Bachelor's, Master's, PhD, Other. Dropdown. Required."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
