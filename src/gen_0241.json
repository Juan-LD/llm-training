{
    "prompt": {
        "EN": "Generate a 2-screen aquarium feedback flow. Screen 1: favorite animals (checkbox: Penguin, Jelly fish, Dolphin, Polar bear) required + liked environment (Yes/No radio) required. Screen 2: enjoyed visit (Yes/No radio) required + optional notes textarea. Navigate from screen 1 to screen 2. Complete on screen 2 with all data. Use camelCase field names."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Which animal(s) did you like seeing the most?"
                                        },
                                        {
                                            "type": "CheckboxGroup",
                                            "label": "Favorite animals",
                                            "name": "favoriteAnimals",
                                            "required": true,
                                            "data-source": [
                                                { "id": "penguin", "title": "Penguin" },
                                                { "id": "jellyfish", "title": "Jelly fish" },
                                                { "id": "dolphin", "title": "Dolphin" },
                                                { "id": "polarBear", "title": "Polar bear" }
                                            ]
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "Did you like the environment?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Yes or No",
                                            "name": "likedEnvironment",
                                            "required": true,
                                            "data-source": [
                                                { "id": "yes", "title": "Yes" },
                                                { "id": "no", "title": "No" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Continue",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "FINAL_NOTES", "type": "screen" },
                                                "payload": {
                                                    "favoriteAnimals": "${form.favoriteAnimals}",
                                                    "likedEnvironment": "${form.likedEnvironment}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Aquarium visit"
                    },
                    {
                        "data": {
                            "favoriteAnimals": { "__example__": ["dolphin"], "type": "array" },
                            "likedEnvironment": { "__example__": "yes", "type": "string" }
                        },
                        "id": "FINAL_NOTES",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Did you enjoy your visit?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Yes or No",
                                            "name": "enjoyedVisit",
                                            "required": true,
                                            "data-source": [
                                                { "id": "yes", "title": "Yes" },
                                                { "id": "no", "title": "No" }
                                            ]
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "Anything else you want to mention?"
                                        },
                                        {
                                            "type": "TextArea",
                                            "label": "Additional Notes",
                                            "name": "additionalNotes",
                                            "required": false
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "enjoyedVisit": "${form.enjoyedVisit}",
                                                    "additionalNotes": "${form.additionalNotes}",
                                                    "favoriteAnimals": "${data.favoriteAnimals}",
                                                    "likedEnvironment": "${data.likedEnvironment}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Final notes"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "CheckboxGroup",
                                            "name": "animals",
                                            "required": true,
                                            "data-source": [
                                                { "id": "dolphin", "title": "Dolphin" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "FINAL_NOTES", "type": "screen" },
                                                "payload": {
                                                    "favAnimals": "${form.animals}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Aquarium"
                    },
                    {
                        "data": {},
                        "id": "FINAL_NOTES",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "onlyAnimals": "${data.favAnimals}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Done"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
