{
    "prompt": {
        "EN": "Design a one-screen WhatsApp flow for work absence justification. Dropdown for reason (Being sick, Feeling tired, Other responsibilities, Other). Radio for vacation day option. Both required. Use camelCase. Complete action."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Youre not going to work today? Why?"
                                        },
                                        {
                                            "type": "Dropdown",
                                            "label": "No work today due to",
                                            "name": "absenceReason",
                                            "required": true,
                                            "data-source": [
                                                { "id": "beingSick", "title": "Being sick" },
                                                { "id": "feelingTired", "title": "Feeling tired" },
                                                { "id": "otherResponsibilities", "title": "Other responsibilities" },
                                                { "id": "other", "title": "Other" }
                                            ]
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Mark as vacation day?",
                                            "name": "markAsVacation",
                                            "required": true,
                                            "data-source": [
                                                { "id": "vacationDay", "title": "Mark as a vacation day" },
                                                { "id": "deductFromSalary", "title": "Take away from salary" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "absenceReason": "${form.absenceReason}",
                                                    "markAsVacation": "${form.markAsVacation}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Skipping working justification"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "SCREEN_A",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Reason?"
                                        },
                                        {
                                            "type": "Dropdown",
                                            "name": "reason",
                                            "required": true,
                                            "data-source": [
                                                { "id": "sick", "title": "Sick" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "RECOMMEND", "type": "screen" },
                                                "payload": {
                                                    "reasonVal": "${form.reason}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "a",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Reason",
                        "terminal": false
                    },
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "vacation",
                                            "required": true,
                                            "data-source": []
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "finalReason": "${data.reasonVal}",
                                                    "finalVacation": "${form.vacation}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "b",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Vacation"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
