{
    "prompt": {
        "EN": "Generate an aquarium feedback flow. One screen. Rating dropdown (5-star scale) required. Comments textarea optional with 200 max chars and helper text. Complete action. Use camelCase: rating, comments."
    },
    "ok_flows": [
        {
            "EN": {
                "version": "7.3",
                "screens": [
                    {
                        "id": "FEEDBACK_SCREEN",
                        "title": "Rate Your Visit",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "TextSubheading",
                                    "text": "How was your experience at the aquarium?"
                                },
                                {
                                    "type": "Form",
                                    "name": "feedbackForm",
                                    "children": [
                                        {
                                            "type": "Dropdown",
                                            "label": "Overall experience",
                                            "required": true,
                                            "name": "rating",
                                            "data-source": [
                                                { "id": "excellent", "title": "★★★★★ • Excellent (5/5)" },
                                                { "id": "good", "title": "★★★★☆ • Good (4/5)" },
                                                { "id": "average", "title": "★★★☆☆ • Average (3/5)" },
                                                { "id": "poor", "title": "★★☆☆☆ • Poor (2/5)" },
                                                { "id": "veryPoor", "title": "★☆☆☆☆ • Very Poor (1/5)" }
                                            ]
                                        },
                                        {
                                            "type": "TextArea",
                                            "name": "comments",
                                            "label": "Any comments?",
                                            "max-length": 200,
                                            "helper-text": "Tell us what you loved or how we can improve"
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Submit Feedback",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "rating": "${form.rating}",
                                                    "comments": "${form.comments}"
                                                }
                                            }
                                        }
                                    ]
                                }
                            ]
                        },
                        "terminal": true
                    }
                ]
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "version": "7.3",
                "screens": [
                    {
                        "id": "ONE",
                        "title": "Feedback",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "Dropdown",
                                    "name": "ratingDrop",
                                    "required": true,
                                    "data-source": [
                                        { "id": "excellent", "title": "Excellent" },
                                        { "id": "good", "title": "Good" }
                                    ]
                                },
                                {
                                    "type": "Footer",
                                    "label": "Next",
                                    "on-click-action": {
                                        "name": "navigate",
                                        "next": { "name": "TWO", "type": "screen" },
                                        "payload": { "ratingVal": "${form.ratingDrop}" }
                                    }
                                }
                            ]
                        },
                        "terminal": false
                    },
                    {
                        "id": "TWO",
                        "title": "Comments",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "TextInput",
                                    "name": "commentText",
                                    "required": true
                                },
                                {
                                    "type": "Footer",
                                    "label": "Finish",
                                    "on-click-action": {
                                        "name": "complete",
                                        "payload": { "finalRating": "${data.ratingVal}", "finalComment": "${form.commentText}" }
                                    }
                                }
                            ]
                        },
                        "terminal": false
                    }
                ]
            }
        }
    ]
}
