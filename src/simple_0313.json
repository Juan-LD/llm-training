{
    "prompt": {
        "EN": "Create a one-screen work absence survey. Dropdown for absence reason (4 options). Radio for vacation day option (2 options). Both required. Complete action. Use camelCase: absenceReason, markAsVacation."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Youre not going to work today? Why?"
                                        },
                                        {
                                            "type": "Dropdown",
                                            "label": "No work today due to",
                                            "name": "absenceReason",
                                            "required": true,
                                            "data-source": [
                                                { "id": "beingSick", "title": "Being sick" },
                                                { "id": "feelingTired", "title": "Feeling tired" },
                                                { "id": "otherResponsibilities", "title": "Other responsibilities" },
                                                { "id": "other", "title": "Other" }
                                            ]
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Mark as vacation day?",
                                            "name": "markAsVacation",
                                            "required": true,
                                            "data-source": [
                                                { "id": "vacationDay", "title": "Mark as a vacation day" },
                                                { "id": "deductFromSalary", "title": "Take away from salary" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "absenceReason": "${form.absenceReason}",
                                                    "markAsVacation": "${form.markAsVacation}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Skipping working justification"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "PAGE1",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "Dropdown",
                                            "name": "reasonDrop",
                                            "required": true,
                                            "data-source": [
                                                { "id": "sick", "title": "Sick" },
                                                { "id": "tired", "title": "Tired" }
                                            ]
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "vacationRadio",
                                            "required": true,
                                            "data-source": [
                                                { "id": "vacation", "title": "Vacation" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "RECOMMEND", "type": "screen" },
                                                "payload": {
                                                    "r": "${form.reasonDrop}",
                                                    "v": "${form.vacationRadio}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "form1",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Step1",
                        "terminal": false
                    },
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextArea",
                                            "name": "extra",
                                            "required": false
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "finalReason": "${data.r}",
                                                    "finalVacation": "${data.v}",
                                                    "finalExtra": "${form.extra}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "form2",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": false,
                        "title": "Step2"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
