{
    "prompt": {
        "EN": "Ask user for expected arrival date. Date picker mandatory. No text input. Must select valid date."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Expected arrival date"
                                        },
                                        {
                                            "label": "Choose",
                                            "name": "arrivalDate",
                                            "required": true,
                                            "type": "DatePicker"
                                        },
                                        {
                                            "label": "Done",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "arrivalDate": "${form.arrivalDate}"
                                                }
                                            },
                                            "type": "Footer"
                                        }
                                    ],
                                    "name": "flow_path",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Arrival"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
