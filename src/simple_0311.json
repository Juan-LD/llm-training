{
    "prompt": {
        "EN": "Generate a one-screen work absence justification flow. Dropdown for reason (Being sick, Feeling tired, Other responsibilities, Other) required. Radio for 'Mark as vacation day?' (Mark as a vacation day, Take away from salary) required. Complete action submits both. Use camelCase: absenceReason, markAsVacation."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Youre not going to work today? Why?"
                                        },
                                        {
                                            "type": "Dropdown",
                                            "label": "No work today due to",
                                            "name": "absenceReason",
                                            "required": true,
                                            "data-source": [
                                                { "id": "beingSick", "title": "Being sick" },
                                                { "id": "feelingTired", "title": "Feeling tired" },
                                                { "id": "otherResponsibilities", "title": "Other responsibilities" },
                                                { "id": "other", "title": "Other" }
                                            ]
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Mark as vacation day?",
                                            "name": "markAsVacation",
                                            "required": true,
                                            "data-source": [
                                                { "id": "vacationDay", "title": "Mark as a vacation day" },
                                                { "id": "deductFromSalary", "title": "Take away from salary" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "absenceReason": "${form.absenceReason}",
                                                    "markAsVacation": "${form.markAsVacation}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Skipping working justification"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "Dropdown",
                                            "name": "reason",
                                            "required": true,
                                            "data-source": [
                                                { "id": "sick", "title": "Sick" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Submit",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "onlyReason": "${form.reason}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Absence"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
