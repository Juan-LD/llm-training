{
    "prompt": {
        "EN": "Extract the user's birthday date."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Plese provide your birthday"
                                        },
                                        {
                                            "label": "Insert your birthday",
                                            "name": "birthdayDate",
                                            "required": true,
                                            "type": "DatePicker"
                                        },
                                        {
                                            "label": "Send",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "birthdayDate": "${form.birthdayDate}"
                                                }
                                            },
                                            "type": "Footer"
                                        }
                                    ],
                                    "name": "flow_path",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Birthday information"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
