{
    "prompt": {
        "EN": "I need a flow where customers report issues. First screen: Address (call it 'Client_Address'), issue type (call it 'Issue_Type' with options plumbing, electrical, hvac, appliance). Second screen: urgency (call it 'Urgency_Level') and a record button (call it 'Record_Issue'). Use underscores and capitals as you like."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Type your address"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "text",
                                            "label": "John Doe 215 S ...",
                                            "name": "address",
                                            "required": true
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "What type of issue is it?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Issue type",
                                            "name": "issueType",
                                            "required": true,
                                            "data-source": [
                                                { "id": "plumbing", "title": "Plumbing" },
                                                { "id": "electrical", "title": "Electrical" },
                                                { "id": "hvac", "title": "HVAC" },
                                                { "id": "appliance", "title": "Appliance" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Continue",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "RATE", "type": "screen" },
                                                "payload": {
                                                    "address": "${form.address}",
                                                    "issueType": "${form.issueType}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Issue general problem"
                    },
                    {
                        "data": {
                            "address": { "__example__": "123 Main St", "type": "string" },
                            "issueType": { "__example__": "plumbing", "type": "string" }
                        },
                        "id": "RATE",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Select how much this problem needs to be fixed."
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Urgency level",
                                            "name": "urgencyLevel",
                                            "required": true,
                                            "data-source": [
                                                { "id": "emergency", "title": "Emergency" },
                                                { "id": "soon", "title": "Soon" },
                                                { "id": "schedule", "title": "Schedule" }
                                            ]
                                        },
                                        {
                                            "type": "OptIn",
                                            "label": "Record this problem",
                                            "name": "recordProblem",
                                            "required": false
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Done",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "urgencyLevel": "${form.urgencyLevel}",
                                                    "recordProblem": "${form.recordProblem}",
                                                    "address": "${data.address}",
                                                    "issueType": "${data.issueType}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Specific problem information"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "name": "Client_Address",
                                            "required": true
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "Issue_Type",
                                            "required": true,
                                            "data-source": [
                                                { "id": "Plumbing", "title": "Plumbing" },
                                                { "id": "Electrical", "title": "Electrical" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Continue",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "RATE", "type": "screen" },
                                                "payload": {
                                                    "ClientAddr": "${form.Client_Address}",
                                                    "IssueCat": "${form.Issue_Type}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flow_path",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Report"
                    },
                    {
                        "data": {},
                        "id": "RATE",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "Urgency_Level",
                                            "required": true,
                                            "data-source": [
                                                { "id": "Emergency", "title": "Emergency" }
                                            ]
                                        },
                                        {
                                            "type": "OptIn",
                                            "name": "Record_Issue",
                                            "required": false
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Done",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "Urgency": "${form.Urgency_Level}",
                                                    "Record": "${form.Record_Issue}",
                                                    "Address": "${data.ClientAddr}",
                                                    "Issue": "${data.IssueCat}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flow_path",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Final"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
