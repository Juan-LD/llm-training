{
    "prompt": {
        "EN": "Generate a one-screen car registration flow. Heading: 'Car license plate?' Text input for license plate number (required). Complete action submits the plate. Use camelCase: licensePlate."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Car license plate?"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "text",
                                            "label": "AA-123-AA",
                                            "name": "licensePlate",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Register",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "licensePlate": "${form.licensePlate}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Register car"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "name": "plate",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Submit",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "onlyPlate": "${form.plate}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Register"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
