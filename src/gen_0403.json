{
    "prompt": {
        "EN": "Create a newsletter signup flow. Email field required (email type). Checkbox group with 4 interest options. Opt-in for extra updates. Complete action. Use camelCase."
    },
    "ok_flows": [
        {
            "EN": {
                "version": "7.3",
                "screens": [
                    {
                        "id": "NEWSLETTER_SCREEN",
                        "title": "Stay Updated",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "TextSubheading",
                                    "text": "Get aquarium news, events & special offers"
                                },
                                {
                                    "type": "Form",
                                    "name": "newsletterForm",
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "name": "email",
                                            "label": "Email address",
                                            "input-type": "email",
                                            "required": true
                                        },
                                        {
                                            "type": "CheckboxGroup",
                                            "name": "interests",
                                            "label": "Interested in",
                                            "data-source": [
                                                { "id": "events", "title": "Special events" },
                                                { "id": "discounts", "title": "Discounts & offers" },
                                                { "id": "education", "title": "Educational programs" },
                                                { "id": "animals", "title": "New animal arrivals" }
                                            ]
                                        },
                                        {
                                            "type": "OptIn",
                                            "name": "extra",
                                            "label": "Receive other extra updates"
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Subscribe",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "subscriberEmail": "${form.email}",
                                                    "interests": "${form.interests}",
                                                    "allowExtra": "${form.extra}"
                                                }
                                            }
                                        }
                                    ]
                                }
                            ]
                        },
                        "terminal": true
                    }
                ]
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "version": "7.3",
                "screens": [
                    {
                        "id": "PAGE1",
                        "title": "Sign Up",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "TextInput",
                                    "name": "mail",
                                    "label": "Your email",
                                    "input-type": "text",
                                    "required": true
                                },
                                {
                                    "type": "Footer",
                                    "label": "Next",
                                    "on-click-action": {
                                        "name": "navigate",
                                        "next": { "name": "PAGE2", "type": "screen" },
                                        "payload": { "emailVal": "${form.mail}" }
                                    }
                                }
                            ]
                        },
                        "terminal": false
                    },
                    {
                        "id": "PAGE2",
                        "title": "Preferences",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "RadioButtonsGroup",
                                    "name": "interestChoice",
                                    "required": true,
                                    "data-source": []
                                },
                                {
                                    "type": "Footer",
                                    "label": "Finish",
                                    "on-click-action": {
                                        "name": "complete",
                                        "payload": { "finalEmail": "${data.emailVal}", "finalInterest": "${form.interestChoice}" }
                                    }
                                }
                            ]
                        },
                        "terminal": true
                    }
                ]
            }
        }
    ]
}
