{
    "prompt": {
        "EN": "Create an order issue survey. Screen 1: extra notes (optional) + consent opt-in required. Screen 2: order number, issue type (radio with 3 options), arrival date. Navigate then complete. Use camelCase field names."
    },
    "ok_flows": [
        {
            "EN": {
        "screens": [
          {
            "data": {},
            "id": "screen_tosexy",
            "layout": {
              "children": [
                {
                  "children": [
                    {
                      "type": "TextSubheading",
                      "text": "Extra notes"
                    },
                    {
                      "type": "TextArea",
                      "label": "Write notes here",
                      "name": "extraNotes",
                      "required": false
                    },
                    {
                      "type": "OptIn",
                      "label": "I agree to use this information to make this service better.",
                      "name": "consentToImprove",
                      "required": true
                    },
                    {
                      "type": "Footer",
                      "label": "Finish",
                      "on-click-action": {
                        "name": "navigate",
                        "next": { "name": "RECOMMEND", "type": "screen" },
                        "payload": {
                          "extraNotes": "${form.extraNotes}",
                          "consentToImprove": "${form.consentToImprove}"
                        }
                      }
                    }
                  ],
                  "name": "flowPath",
                  "type": "Form"
                }
              ],
              "type": "SingleColumnLayout"
            },
            "title": "Finish"
          },
          {
            "data": {
              "extraNotes": { "__example__": "Example", "type": "string" },
              "consentToImprove": { "__example__": false, "type": "boolean" }
            },
            "id": "RECOMMEND",
            "layout": {
              "children": [
                {
                  "children": [
                    {
                      "type": "TextSubheading",
                      "text": "Which order do you want us to check?"
                    },
                    {
                      "type": "TextInput",
                      "input-type": "number",
                      "label": "Order number...",
                      "name": "orderNumber",
                      "required": true
                    },
                    {
                      "type": "TextSubheading",
                      "text": "What happened?"
                    },
                    {
                      "type": "RadioButtonsGroup",
                      "label": "What happened to your order?",
                      "name": "orderIssue",
                      "required": true,
                      "data-source": [
                        { "id": "notArrived", "title": "Wasnt arrived yet" },
                        { "id": "cameDamaged", "title": "Came damaged" },
                        { "id": "missingItems", "title": "Missing items" }
                      ]
                    },
                    {
                      "type": "TextSubheading",
                      "text": "Date of arrival (or estimated)"
                    },
                    {
                      "type": "DatePicker",
                      "label": "Date",
                      "name": "arrivalDate",
                      "required": true
                    },
                    {
                      "type": "Footer",
                      "label": "Continue",
                      "on-click-action": {
                        "name": "complete",
                        "payload": {
                          "orderNumber": "${form.orderNumber}",
                          "orderIssue": "${form.orderIssue}",
                          "arrivalDate": "${form.arrivalDate}",
                          "extraNotes": "${data.extraNotes}",
                          "consentToImprove": "${data.consentToImprove}"
                        }
                      }
                    }
                  ],
                  "name": "flowPath",
                  "type": "Form"
                }
              ],
              "type": "SingleColumnLayout"
            },
            "terminal": true,
            "title": "Identify Target order"
          }
        ],
        "version": "7.3"
      }
    }
  ],
  "ko_flows": [
    {
      "EN": {
        "screens": [
          {
            "data": {},
            "id": "FIRST",
            "layout": {
              "children": [
                {
                  "children": [
                    {
                      "type": "TextInput",
                      "name": "customOrder",
                      "required": true
                    },
                    {
                      "type": "Footer",
                      "label": "Next",
                      "on-click-action": {
                        "name": "navigate",
                        "next": { "name": "RECOMMEND", "type": "screen" },
                        "payload": {
                          "orderText": "${form.customOrder}"
                        }
                      }
                    }
                  ],
                  "name": "p",
                  "type": "Form"
                }
              ],
              "type": "SingleColumnLayout"
            },
            "title": "Order",
            "terminal": false
          },
          {
            "data": {},
            "id": "RECOMMEND",
            "layout": {
              "children": [
                {
                  "children": [
                    {
                      "type": "RadioButtonsGroup",
                      "name": "issueRadio",
                      "required": true,
                      "data-source": [
                        { "id": "yes", "title": "Yes" },
                        { "id": "no", "title": "No" }
                      ]
                    },
                    {
                      "type": "Footer",
                      "label": "Finish",
                      "on-click-action": {
                        "name": "complete",
                        "payload": {
                          "finalOrder": "${data.orderText}",
                          "finalIssue": "${form.issueRadio}"
                        }
                      }
                    }
                  ],
                  "name": "p",
                  "type": "Form"
                }
              ],
              "type": "SingleColumnLayout"
            },
            "terminal": false,
            "title": "Issue"
          }
        ],
        "version": "7.0"
      }
    }
  ]
}
