{
    "prompt": {
        "EN": "Generate an order rescheduling flow. One screen. Heading: 'Your order did not arrive! Please mark another day here.' Date picker required. Complete action. Use camelCase: newDeliveryDate."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Your order did not arrive! Please mark another day here."
                                        },
                                        {
                                            "type": "DatePicker",
                                            "label": "Select new delivery date",
                                            "name": "newDeliveryDate",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "newDeliveryDate": "${form.newDeliveryDate}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Order didnt arrive!"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "ONE",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "New date"
                                        },
                                        {
                                            "type": "DatePicker",
                                            "name": "newDate",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "RECOMMEND", "type": "screen" },
                                                "payload": {
                                                    "dateChoice": "${form.newDate}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "f",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Pick",
                        "terminal": false
                    },
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "confirmRadio",
                                            "required": true,
                                            "data-source": [
                                                { "id": "yes", "title": "Yes" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "finalDate": "${data.dateChoice}",
                                                    "finalConfirm": "${form.confirmRadio}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "f",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": false,
                        "title": "Confirm"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
