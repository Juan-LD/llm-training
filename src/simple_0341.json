{
    "prompt": {
        "EN": "Generate a one-screen price suggestion flow. Heading: 'What price should the hotdog be?' Number input for price (required). Complete action submits the price. Use camelCase: suggestedPrice."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "What price should the hotdog be?"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "number",
                                            "label": "12,34",
                                            "name": "suggestedPrice",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Register",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "suggestedPrice": "${form.suggestedPrice}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Suggest price change"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "input-type": "number",
                                            "name": "price",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Submit",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "onlyPrice": "${form.price}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Price"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
