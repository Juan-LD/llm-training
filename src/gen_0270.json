{
    "prompt": {
        "EN": "Build a 2-screen work feedback flow. First screen: comfortable at work (Yes/No) and general mood (checkbox with 5 options). Second screen: required notes textarea. Use camelCase field names: comfortableAtWork, generalMood, extraNotes. Navigate then complete."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Do you feel comfortable at work?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Yes or No",
                                            "name": "comfortableAtWork",
                                            "required": true,
                                            "data-source": [
                                                { "id": "yes", "title": "Yes" },
                                                { "id": "no", "title": "No" }
                                            ]
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "What is your general mood at work?"
                                        },
                                        {
                                            "type": "CheckboxGroup",
                                            "label": "Mood",
                                            "name": "generalMood",
                                            "required": true,
                                            "data-source": [
                                                { "id": "sleepy", "title": "Sleepy" },
                                                { "id": "bored", "title": "Bored" },
                                                { "id": "happy", "title": "Happy" },
                                                { "id": "energized", "title": "Energized" },
                                                { "id": "tired", "title": "Tired" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Continue",
                                            "on-click-action": {
                                                "name": "navigate",
                                                "next": { "name": "EXTRA_NOTES", "type": "screen" },
                                                "payload": {
                                                    "comfortableAtWork": "${form.comfortableAtWork}",
                                                    "generalMood": "${form.generalMood}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Work feedback"
                    },
                    {
                        "data": {
                            "comfortableAtWork": { "__example__": "yes", "type": "string" },
                            "generalMood": { "__example__": ["happy"], "items": { "type": "string" }, "type": "array" }
                        },
                        "id": "EXTRA_NOTES",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextSubheading",
                                            "text": "Extra Notes"
                                        },
                                        {
                                            "type": "TextArea",
                                            "label": "Write any notes here",
                                            "name": "extraNotes",
                                            "required": true
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "extraNotes": "${form.extraNotes}",
                                                    "comfortableAtWork": "${data.comfortableAtWork}",
                                                    "generalMood": "${data.generalMood}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Work feedback notes"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "FIRST",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "CheckboxGroup",
                                            "name": "mood",
                                            "required": false,
                                            "data-source": [
                                                { "id": "happy", "title": "Happy" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Next",
                                            "on-click-action": {
                                                "name": "go",
                                                "next": { "name": "SECOND", "type": "screen" },
                                                "payload": {
                                                    "moodData": "${form.mood}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flow",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "title": "Mood",
                        "terminal": false
                    },
                    {
                        "data": {},
                        "id": "SECOND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "RadioButtonsGroup",
                                            "name": "comfort",
                                            "required": false,
                                            "data-source": []
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "submit",
                                                "payload": {
                                                    "finalMood": "${data.moodData}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flow",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Comfort"
                    }
                ],
                "version": "7.2"
            }
        }
    ]
}
