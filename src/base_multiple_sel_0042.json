{
    "prompt": {
        "EN": "Ask user which countries they have visited. Options: Portugal, Spain, Malta, Germany, Switzerland, Turkey. Use checkboxes for multi-select. Required."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Which countries have you been to?"
                                        },
                                        {
                                            "data-source": [
                                                {"id": "0_Portugal", "title": "Portugal"},
                                                {"id": "1_Spain", "title": "Spain"},
                                                {"id": "2_Malta", "title": "Malta"},
                                                {"id": "3_Germany", "title": "Germany"},
                                                {"id": "4_Switzerland", "title": "Switzerland"},
                                                {"id": "5_Turkey", "title": "Turkey"}
                                            ],
                                            "label": "Select where you have been",
                                            "name": "visitedCountries",
                                            "required": true,
                                            "type": "CheckboxGroup"
                                        },
                                        {
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "visitedCountries": "${form.visitedCountries}"
                                                }
                                            },
                                            "type": "Footer"
                                        }
                                    ],
                                    "name": "flow_path",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Travel History"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "What is your mother's maiden name?"
                                        },
                                        {
                                            "data-source": [
                                                {"id": "0_Portugal", "title": "Portugal"},
                                                {"id": "1_Spain", "title": "Spain"},
                                                {"id": "2_Malta", "title": "Malta"},
                                                {"id": "3_Germany", "title": "Germany"},
                                                {"id": "4_Switzerland", "title": "Switzerland"},
                                                {"id": "5_Turkey", "title": "Turkey"}
                                            ],
                                            "label": "Select where you have been",
                                            "name": "mothersMaidenName",
                                            "required": true,
                                            "type": "CheckboxGroup"
                                        },
                                        {
                                            "label": "Finish",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "visitedCountries": "${form.mothersMaidenName}"
                                                }
                                            },
                                            "type": "Footer"
                                        }
                                    ],
                                    "name": "flow_path",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Security"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
