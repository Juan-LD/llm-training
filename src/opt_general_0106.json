{
    "prompt": {
        "EN": "I need a travel form with fields: destination_country, arrival_date, departure_date, number_of_people (1 to 5+). Use snake_case for everything. Also make the people field a dropdown with options 'one' 'two' etc. Thanks."
    },
    "ok_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextHeading",
                                            "text": "Which country do you wish to visit?"
                                        },
                                        {
                                            "type": "TextInput",
                                            "input-type": "text",
                                            "label": "Portugal",
                                            "name": "destination",
                                            "required": true
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "When do you plan to arrive?"
                                        },
                                        {
                                            "type": "DatePicker",
                                            "label": "12/12/2012",
                                            "name": "arrivalDate",
                                            "required": true
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "When do you plan to leave?"
                                        },
                                        {
                                            "type": "DatePicker",
                                            "label": "24/12/2012",
                                            "name": "departureDate",
                                            "required": true
                                        },
                                        {
                                            "type": "TextSubheading",
                                            "text": "How many people are going?"
                                        },
                                        {
                                            "type": "RadioButtonsGroup",
                                            "label": "Number of additional people",
                                            "name": "numberOfPeople",
                                            "required": true,
                                            "data-source": [
                                                { "id": "1", "title": "1" },
                                                { "id": "2", "title": "2" },
                                                { "id": "3", "title": "3" },
                                                { "id": "4", "title": "4" },
                                                { "id": "5", "title": "5" },
                                                { "id": "5plus", "title": "5 +" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Book",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "destination": "${form.destination}",
                                                    "arrivalDate": "${form.arrivalDate}",
                                                    "departureDate": "${form.departureDate}",
                                                    "numberOfPeople": "${form.numberOfPeople}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flowPath",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Travel Itinerary"
                    }
                ],
                "version": "7.3"
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "screens": [
                    {
                        "data": {},
                        "id": "RECOMMEND",
                        "layout": {
                            "children": [
                                {
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "name": "destination_country",
                                            "required": true
                                        },
                                        {
                                            "type": "DatePicker",
                                            "name": "arrival_date",
                                            "required": true
                                        },
                                        {
                                            "type": "DatePicker",
                                            "name": "departure_date",
                                            "required": true
                                        },
                                        {
                                            "type": "Dropdown",
                                            "name": "number_of_people",
                                            "required": true,
                                            "data-source": [
                                                { "id": "one", "title": "one" },
                                                { "id": "two", "title": "two" }
                                            ]
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Book",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "dest": "${form.destination_country}",
                                                    "arrive": "${form.arrival_date}",
                                                    "leave": "${form.departure_date}",
                                                    "people": "${form.number_of_people}"
                                                }
                                            }
                                        }
                                    ],
                                    "name": "flow_path",
                                    "type": "Form"
                                }
                            ],
                            "type": "SingleColumnLayout"
                        },
                        "terminal": true,
                        "title": "Travel_Form"
                    }
                ],
                "version": "7.3"
            }
        }
    ]
}
