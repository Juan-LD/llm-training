{
    "prompt": {
        "EN": "Generate a newsletter subscription flow. One screen. Email required (email type). Checkbox group for interests (Special events, Discounts & offers, Educational programs, New animal arrivals). Opt-in for extra updates. Complete action. Use camelCase. Include example data."
    },
    "ok_flows": [
        {
            "EN": {
                "version": "7.3",
                "screens": [
                    {
                        "id": "NEWSLETTER_SCREEN",
                        "title": "Stay Updated",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "TextSubheading",
                                    "text": "Get aquarium news, events & special offers"
                                },
                                {
                                    "type": "Form",
                                    "name": "newsletterForm",
                                    "children": [
                                        {
                                            "type": "TextInput",
                                            "name": "email",
                                            "label": "Email address",
                                            "input-type": "email",
                                            "required": true
                                        },
                                        {
                                            "type": "CheckboxGroup",
                                            "name": "interests",
                                            "label": "Interested in",
                                            "data-source": [
                                                { "id": "events", "title": "Special events" },
                                                { "id": "discounts", "title": "Discounts & offers" },
                                                { "id": "education", "title": "Educational programs" },
                                                { "id": "animals", "title": "New animal arrivals" }
                                            ]
                                        },
                                        {
                                            "type": "OptIn",
                                            "name": "extra",
                                            "label": "Receive other extra updates"
                                        },
                                        {
                                            "type": "Footer",
                                            "label": "Subscribe",
                                            "on-click-action": {
                                                "name": "complete",
                                                "payload": {
                                                    "subscriberEmail": "${form.email}",
                                                    "interests": "${form.interests}",
                                                    "allowExtra": "${form.extra}"
                                                }
                                            }
                                        }
                                    ]
                                }
                            ]
                        },
                        "terminal": true
                    }
                ]
            }
        }
    ],
    "ko_flows": [
        {
            "EN": {
                "version": "7.3",
                "screens": [
                    {
                        "id": "STEP_ONE",
                        "title": "News",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "TextInput",
                                    "name": "emailInput",
                                    "label": "Email",
                                    "input-type": "email",
                                    "required": true
                                },
                                {
                                    "type": "Footer",
                                    "label": "Next",
                                    "on-click-action": {
                                        "name": "navigate",
                                        "next": { "name": "STEP_TWO", "type": "screen" },
                                        "payload": { "mail": "${form.emailInput}" }
                                    }
                                }
                            ]
                        },
                        "terminal": false
                    },
                    {
                        "id": "STEP_TWO",
                        "title": "Preferences",
                        "data": {},
                        "layout": {
                            "type": "SingleColumnLayout",
                            "children": [
                                {
                                    "type": "TextArea",
                                    "name": "notesArea",
                                    "required": false
                                },
                                {
                                    "type": "Footer",
                                    "label": "Finish",
                                    "on-click-action": {
                                        "name": "complete",
                                        "payload": { "finalEmail": "${data.mail}", "finalNotes": "${form.notesArea}" }
                                    }
                                }
                            ]
                        },
                        "terminal": true
                    }
                ]
            }
        }
    ]
}
